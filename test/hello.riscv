  .text
  .globl main
main:
  addi sp, sp, -16
  li t0, 1
  li t1, 0
  xor t2, t0, t1
  snez t2, t2
  sw t2, 0(sp)
  li t0, 2
  li t1, 0
  xor t2, t0, t1
  snez t2, t2
  sw t2, 4(sp)
  lw t0, 0(sp)
  lw t1, 4(sp)
  snez t0, t0
  snez t1, t1
  or t2, t0, t1
  sw t2, 8(sp)
  lw a0, 8(sp)
  addi sp, sp, 16
  ret
